# Normalize line endings: Git stores LF, checks out native on working tree
* text=auto

# Force LF for source and configuration files for deterministic, cross-platform builds
*.cs        text eol=lf
*.csproj    text eol=lf
*.slnx      text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.json      text eol=lf
*.editorconfig text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Treat known binary types as binary (no EOL conversion)
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.snk       binary
*.pfx       binary
*.nupkg     binary
*.snupkg    binary
